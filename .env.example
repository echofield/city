# Supabase (server prefers non-public names; NEXT_PUBLIC_* kept as fallback)
SUPABASE_URL=https://your-project.supabase.co
# New publishable key format (recommended): sb_publishable_...
# Legacy anon JWT also works. RLS enforced; compatible with Edge Functions.
SUPABASE_ANON_KEY=sb_publishable_...
# Or: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
# Optional: server-side writes only (ingest/webhook). Bypasses RLS; keep secret. Not used for loadCitySignalsAsync.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CORS: set in production to your frontend URL (e.g. https://your-frontend.vercel.app). Avoid * in prod if you use cookies later.
ALLOWED_ORIGINS=https://your-frontend.vercel.app
