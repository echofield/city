# Flow Frontend Configuration
# Copy this file to .env.local and adjust as needed

# ============================================
# DATA MODE CONFIGURATION
# ============================================

# API Mode (default: false)
# When true: fetches FlowState from backend API
# When false: uses local engine for development/testing
VITE_USE_API=false

# API Base URL (empty for same-origin)
# Set this to your backend URL when using API mode
# Example: https://flow-api.example.com
VITE_API_URL=

# ============================================
# CITY CONFIGURATION
# ============================================

# City ID for API requests (default: paris)
# Supported cities: paris (more coming)
VITE_CITY_ID=paris

# ============================================
# RUNNING MODES
# ============================================
#
# 1. LOCAL FALLBACK MODE (development)
#    - Set VITE_USE_API=false
#    - Uses local FlowEngine computation
#    - No backend required
#    - Best for UI development
#
# 2. API MODE (production)
#    - Set VITE_USE_API=true
#    - Set VITE_API_URL to your backend
#    - Fetches real data from Flow API
#    - Required for driver testing
#
# 3. DEBUG MODE (always available in dev)
#    - Shows DBG panel in bottom-right
#    - Click to expand comparison view
#    - Shows local vs API signal counts
#    - Only visible when NODE_ENV=development
#
# ============================================
# QUICK START
# ============================================
#
# Development (local mode):
#   npm run dev
#
# Development (API mode):
#   VITE_USE_API=true VITE_API_URL=http://localhost:3000 npm run dev
#
# Production build:
#   npm run build
#
# Preview production build:
#   npm run preview
