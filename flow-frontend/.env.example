# Backend (city-flow) base URL for GET /api/flow/state.
# Leave unset or empty to use Vite proxy (/api → http://localhost:3000); no CORS.
# If backend runs on another port: VITE_FLOW_API_URL=http://localhost:3001
# VITE_FLOW_API_URL=

# Stripe Payment Link v1 (no backend). Set in Stripe Dashboard: Confirmation page → VITE_APP_BASE_URL/success
VITE_STRIPE_PAYMENT_LINK_URL="https://buy.stripe.com/XXXX"
VITE_APP_BASE_URL="http://localhost:5173"
